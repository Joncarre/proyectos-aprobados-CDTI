# ── Backend (API) ─────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3001

# Origin allowed by CORS (the Vite dev server in development)
CORS_ORIGIN=http://localhost:5173

# Requests per minute and per IP before the API answers 429
RATE_LIMIT_MAX=300

# Authentication extension point (not implemented; keep false)
AUTH_ENABLED=false

# ── Database ─────────────────────────────────────────────────
# Path to the DuckDB file generated by the ingest script.
# Relative paths are resolved from the repository root.
DUCKDB_PATH=./data/cdti.duckdb

# ── Ingest ───────────────────────────────────────────────────
# Directory containing the 13 raw JSON files
RAW_DATA_DIR=./data/raw
