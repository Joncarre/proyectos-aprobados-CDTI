# Dependencies
node_modules/

# Builds
dist/
build/
*.tsbuildinfo

# Data: raw JSONs stay local; the built DuckDB is committed so Render can read
# it (regenerate with `npm run ingest` after editing the sources, then commit).
data/raw/*
!data/raw/.gitkeep
data/*.duckdb
!data/cdti.duckdb
data/*.duckdb.wal
data/*.duckdb.tmp

# Environment (never commit secrets)
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# Test coverage
coverage/

# OS / editor noise
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
