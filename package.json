{
  "name": "proyectos-aprobados-cdti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Plataforma de visualización y exploración de los proyectos aprobados por el CDTI",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "shared",
    "ingest",
    "backend",
    "frontend"
  ],
  "scripts": {
    "ingest": "npm run start --workspace ingest",
    "dev:api": "npm run dev --workspace backend",
    "dev:web": "npm run dev --workspace frontend",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
